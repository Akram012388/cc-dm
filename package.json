{
  "name": "cc-dm",
  "version": "1.1.0",
  "description": "Peer-to-peer direct messaging between Claude Code sessions via the Channels protocol",
  "author": "Shaikh Akram Ahmed",
  "license": "MIT",
  "type": "module",
  "main": "src/server.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akram012388/cc-dm.git"
  },
  "homepage": "https://github.com/Akram012388/cc-dm#readme",
  "bugs": {
    "url": "https://github.com/Akram012388/cc-dm/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "channels",
    "plugin",
    "mcp",
    "direct-messaging",
    "multi-session"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src/",
    "skills/",
    ".claude-plugin/plugin.json",
    "install.sh",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun install --no-summary && bun src/server.ts",
    "dev": "bun --watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
